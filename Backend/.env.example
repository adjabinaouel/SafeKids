# Backend SMTP configuration example for SafeKids
# Remplacez ces valeurs par vos identifiants SMTP réels.

SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=YOUR_SMTP_USERNAME
SMTP_PASS=YOUR_SMTP_PASSWORD

# Adresse d'expéditeur visible dans les emails
EMAIL_FROM=no-reply@safekids.app

# URL front-end utilisée dans les emails d'invitation
FRONTEND_URL=http://localhost:19006
